{
  "name": "copycat-chatgpt-app",
  "version": "2.3.0",
  "description": "A multilingual social-deduction game that runs inside ChatGPT.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "topics:sync": "node scripts/sync-topics.mjs",
    "topics:check": "node scripts/sync-topics.mjs --check",
    "check": "npm run topics:check && tsc --noEmit && node --check public/topics.js && node --check public/i18n.js && node --check public/app.js",
    "test": "node tests/run-e2e.mjs",
    "test:e2e": "node tests/e2e.mjs",
    "verify": "npm run check && npm test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
